@inherits RazorSliceHttpResult<Listing>
@implements IUsesLayout<_Layout, Layout>

<article>
    <h1>Latest posts</h1>
    <ul>
        @foreach (var entry in Model.Entries)
        {
            <li>
                <section>
                    <a href="@(entry.Name)">
                        <h3>@(entry.Title)</h3>
                    </a>
                    <div>
                        Author: @entry.AuthorHandle
                    </div>
                    @if (entry.IsPublic)
                    {
                        <div>
                            Public: Yes
                        </div>
                    }
                    <div>
                        Last modified: @(entry.LastModified.ToString("yyyy-MM-dd HH:mm:ss"))
                    </div>
                    @if (entry.ToManagePage != null)
                    {
                        <div>
                            <form action="@entry.ToManagePage" method="get">
                                <input type='submit' value="Manage post" />
                            </form>
                        </div>
                    }
                </section>
            </li>
        }
    </ul>
</article>

@if (Model.CanModify)
{
    <form>
        <input type="submit" formaction="@(Model.ToNewPostPage)" formmethod="get" value="New post" />
    </form>
}

@functions
{
    public Layout LayoutModel => new() { Title = "Posts" };
}
