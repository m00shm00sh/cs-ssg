@inherits RazorSliceHttpResult<LoginSignupForm>
@implements IUsesLayout<_Layout, Layout>

<article class="hcenter">
    <form method="post">
        <h1>Log in / sign up</h1>
        <div>
            <label for="email">Email</label>
        </div>
        <div>
            <input id="email" type="text" maxlength="256" name="email"/>
        </div>
        <div>
            <label for="password">Password</label>
        </div>
        <div>
            <input id="password" type="password" name="password"/>
        </div>
        <div>
            <input type="hidden" name="@(Model.Antiforgery.FormFieldName)" value="@(Model.Antiforgery.RequestToken)"/>
        </div>
        <div>
            <input type="submit" name="loginButton" value="Sign in" formaction="@Model.LoginDestination"/>
        </div>
        @if (Model.SignupDestination is not null)
        {
            <div>
                <input type="submit" name="signupButton" value="Sign up" formaction="@Model.SignupDestination"/>
            </div>        
        }
    </form>
</article>

@functions
{
    public Layout LayoutModel => new() { Title = "Log in / sign up" };
}
